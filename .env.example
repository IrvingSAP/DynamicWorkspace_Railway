# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Incluir variantes con y sin puerto (fetch / CSRF Origin)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://127.0.0.1:8000,http://127.0.0.1:8001,http://localhost,http://localhost:8000,http://localhost:8001

# Database (Railway provides DATABASE_URL)
DATABASE_URL=sqlite:///db.sqlite3

# Resend (solo producción con EMAIL_DELIVERY=resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email — en desarrollo (DEBUG=True) siempre se usa console; los códigos
# aparecen en la terminal donde corre runserver. No hace falta buzón real.
# Producción: EMAIL_DELIVERY=resend
EMAIL_DELIVERY=console
DEFAULT_FROM_EMAIL=DynamicWorkspace <onboarding@resend.dev>
PUBLIC_CONTACT_EMAIL=contacto@dynamicworkspace.app

# --- Producción (Railway) ---
# DJANGO_SETTINGS_MODULE=dynamicworkspace.production
# DEBUG=False
# DATABASE_URL=postgresql://…   (inyectado por Railway)
# CONN_MAX_AGE=600
# DATABASE_SSL_REQUIRE=true
# WEB_CONCURRENCY=3
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
# SECURE_SSL_REDIRECT=true
